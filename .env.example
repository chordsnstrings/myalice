APP_NAME="ARKS Messages Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Production on SiteGround: force https and trust the proxy (§3, §10).
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://app.yourbrand.com
# ASSET_URL=https://app.yourbrand.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Local dev uses sqlite; SiteGround uses MySQL (Site Tools → MySQL).
DB_CONNECTION=sqlite
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# Sessions/cache: Memcached on SiteGround, database fallback. NEVER Redis (§3).
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=database
# CACHE_STORE=memcached
MEMCACHED_HOST=127.0.0.1
MEMCACHED_PORT=11211

# Queue is database-backed and drained by the cron scheduler (§3). No daemon.
QUEUE_CONNECTION=database

# Realtime via hosted Pusher/Ably + Laravel Echo. Degrades to short-poll if unset.
BROADCAST_CONNECTION=log
# BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# User media on S3-compatible storage (R2 / Spaces / Wasabi). Not local disk (§3).
FILESYSTEM_DISK=local
# FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@myalice.test"
MAIL_FROM_NAME="${APP_NAME}"

# --- External provider credentials (thin HTTP clients, §2). Stubbed until set. ---
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WABA_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

MESSENGER_PAGE_TOKEN=
MESSENGER_VERIFY_TOKEN=
INSTAGRAM_PAGE_TOKEN=
INSTAGRAM_VERIFY_TOKEN=

SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

VITE_APP_NAME="${APP_NAME}"
